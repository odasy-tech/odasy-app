# Odasy web — env template.
#
# Public variables must be prefixed NEXT_PUBLIC_. Server-only secrets stay
# unprefixed. In production/preview, pull these via `vercel env pull`.

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ─── Database (Neon) ───────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/odasy?sslmode=require

# ─── AI Gateway ────────────────────────────────────────────────────────────
# On Vercel production, OIDC handles auth automatically.
AI_GATEWAY_API_KEY=

# ─── Observability (optional) ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=
