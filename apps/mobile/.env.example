# Odasy mobile — Expo env template
#
# These are PUBLIC variables that get bundled into the app. Every key MUST
# be prefixed `EXPO_PUBLIC_` so Expo picks it up at build time.
# Validated at startup by `src/lib/env.ts` (Zod).
#
# Copy this file to `.env.local` and fill in real values. Never commit
# `.env.local`.
#
# In production/preview environments, pull these via `vercel env pull`.

# ─── Auth (Clerk publishable key) ────────────────────────────────────────
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ─── Maps (Mapbox GL) ────────────────────────────────────────────────────
EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxx

# ─── tRPC API endpoint ───────────────────────────────────────────────────
# Points at the Next.js admin (apps/admin) when running in dev.
# In production this becomes https://admin.odasy.app/api/trpc.
EXPO_PUBLIC_TRPC_URL=http://localhost:3000/api/trpc

# ─── Observability (optional — leave empty to disable) ──────────────────
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# ─── EAS Build ───────────────────────────────────────────────────────────
# Filled in automatically the first time you run `eas init`.
EAS_PROJECT_ID=
