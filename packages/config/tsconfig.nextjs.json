{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Odasy Next.js",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "allowJs": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }]
  }
}
