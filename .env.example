# Odasy monorepo — root env template
#
# These are SERVER-SIDE variables consumed by scripts, tools, and packages
# that run outside the mobile bundle (Drizzle CLI, vitest suites, EAS hooks,
# Sentry source-map uploads, etc.). Copy this file to `.env.local` and fill
# in real values. Never commit `.env.local`.
#
# Public variables consumed by the Expo bundle live in
# `apps/mobile/.env.local` and must be prefixed `EXPO_PUBLIC_`.
#
# In production/preview environments, pull these via `vercel env pull`.

# ─── Database (Neon via Vercel Marketplace) ──────────────────────────────
# Pooled connection string — used by the Drizzle runtime client.
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/odasy?sslmode=require
# Direct (unpooled) connection — used by drizzle-kit for migrations.
DIRECT_URL=postgres://user:password@ep-xxx.neon.tech/odasy?sslmode=require

# ─── Auth (Clerk) ────────────────────────────────────────────────────────
# Server-side Clerk secret, used by apps/admin and the tRPC middleware.
CLERK_SECRET_KEY=sk_test_xxx

# ─── AI (Vercel AI Gateway) ──────────────────────────────────────────────
# Only needed for local dev. In production on Vercel, OIDC handles auth
# automatically and this variable is ignored.
AI_GATEWAY_API_KEY=

# ─── Storage (Vercel Blob) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Observability (Sentry) ──────────────────────────────────────────────
# Only needed by CI for uploading source maps during release builds.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=odasy-tech
SENTRY_PROJECT=odasy-app

# ─── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=development
